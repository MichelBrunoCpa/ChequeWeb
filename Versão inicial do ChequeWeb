<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width,initial-scale=1.0" />
  <title>Preenchedor de Cheques</title>
  <style>
    :root {
      --fonte-cheque:"Courier New",monospace;
      --peso-padrao:600;
      --tam-valor-num:13pt; --tam-extenso:11pt; --tam-nominal:11pt;
      --tam-data:10pt; --tam-bom-para:9pt;
      --print-offset-x:0mm; --print-offset-y:0mm;
      --bg-primary:#f0f2f5; --bg-secondary:#fff;
      --text-primary:#333; --text-secondary:#555; --text-tertiary:#999;
      --border-color:#ededed;
      --header-bg:linear-gradient(135deg,#1e3c72 0%,#2a5298 100%);
      --accent-color:#2a5298;
      --accent-glow:rgba(42,82,152,0.4);
      --shadow-light:0 4px 15px rgba(0,0,0,0.1);
      --shadow-dark:0 8px 25px rgba(0,0,0,0.15);
      --shadow-inset:inset 0 2px 5px rgba(0,0,0,0.1);
      --cheque-bg-opacity:0.75;
    }

    body.tema-escuro {
      --bg-primary:#1a1a1a; --bg-secondary:#2d2d2d;
      --text-primary:#e0e0e0; --text-secondary:#b0b0b0; --text-tertiary:#808080;
      --border-color:#404040;
      --header-bg:linear-gradient(135deg,#0f1419 0%,#1a2332 100%);
      --accent-color:#4a9eff; --accent-glow:rgba(74,158,255,0.5);
      --shadow-light:0 4px 15px rgba(0,0,0,0.3);
      --shadow-dark:0 8px 25px rgba(0,0,0,0.4);
      --shadow-inset:inset 0 2px 5px rgba(0,0,0,0.3);
    }

    *{margin:0;padding:0;box-sizing:border-box}
    body{font-family:Arial,sans-serif;background:var(--bg-primary);color:var(--text-primary);transition:background-color .3s,color .3s}

    /* ── BOTÕES: base única, variantes só sobrescrevem glow ── */
    .btn,.tab,.top-btn,.btn-direcao button,.modal-btn,.historico-item-actions button{
      border:none;border-radius:8px;padding:10px 12px;font-weight:800;cursor:pointer;
      transition:all .15s ease;position:relative;overflow:hidden;
      box-shadow:var(--shadow-light);
    }
    .btn,.tab,.top-btn,.btn-direcao button,.modal-btn,.historico-item-actions button,
    .btn:hover,.tab:hover:not(.active),.top-btn:hover{
      /* estados definidos abaixo por grupo */
    }
    .btn:hover,.top-btn.light:hover{box-shadow:var(--shadow-dark),0 0 20px var(--accent-glow);transform:translateY(-2px)}
    .btn:active,.top-btn.light:active{box-shadow:var(--shadow-inset),0 2px 5px rgba(0,0,0,.1);transform:translateY(3px)}

    .tab:hover:not(.active){box-shadow:var(--shadow-dark),0 0 15px var(--accent-glow);transform:translateY(-2px)}
    .tab:active:not(.active){box-shadow:var(--shadow-inset),0 2px 5px rgba(0,0,0,.1);transform:translateY(3px)}
    .tab.active{background:var(--accent-color);color:#fff;box-shadow:var(--shadow-dark),0 0 20px var(--accent-glow)}

    .historico-item-actions button:hover{box-shadow:var(--shadow-dark);transform:translateY(-1px)}
    .historico-item-actions button:active{box-shadow:var(--shadow-inset),0 2px 5px rgba(0,0,0,.1);transform:translateY(2px)}

    .modal-btn:hover{box-shadow:var(--shadow-dark);transform:translateY(-2px)}
    .modal-btn:active{box-shadow:var(--shadow-inset),0 2px 5px rgba(0,0,0,.1);transform:translateY(2px)}

    .btn-direcao button:hover{box-shadow:var(--shadow-dark);transform:translateY(-1px)}
    .btn-direcao button:active{box-shadow:var(--shadow-inset),0 2px 5px rgba(0,0,0,.1);transform:translateY(1px)}

    /* ── VARIANTES DE COR ── */
    .btn-primary,.tab.active{background:var(--accent-color);color:#fff}
    .btn-info,.btn-carregar{background:#17a2b8;color:#fff}
    .btn-warning{background:#ffc107;color:#333}
    .btn-danger,.btn-deletar{background:#dc3545;color:#fff} .btn-copia{background:#6B46C1;color:#fff}
    .top-btn.light,.tab{background:#f3f5f7;color:var(--text-primary)}
    body.tema-escuro .top-btn.light,
    body.tema-escuro .tab{background:#3d3d3d;color:#e0e0e0;border:1px solid var(--accent-color)}
    .modal-btn-sim{background:var(--accent-color);color:#fff}
    .modal-btn-nao{background:#e0e0e0;color:#333}
    body.tema-escuro .modal-btn-nao{background:#404040;color:#e0e0e0}

    .btn-full{grid-column:1/-1}
    .btn-small{padding:6px 10px;font-size:12px;border-radius:8px}

    /* ── RIPPLE ── */
    .ripple{position:absolute;border-radius:50%;background:rgba(255,255,255,.6);
      transform:scale(0);animation:ripple-anim .6s ease-out;pointer-events:none}
    @keyframes ripple-anim{to{transform:scale(4);opacity:0}}

    /* ── LAYOUT ── */
    .header{background:var(--header-bg);color:#fff;padding:16px 22px;box-shadow:0 2px 10px rgba(0,0,0,.1)}
    .header-top{display:flex;align-items:center;justify-content:space-between;gap:12px}
    .header h1{font-size:20px;margin:0}
    .header p{font-size:12px;opacity:.95;margin-top:4px}
    .header-right{display:flex;align-items:center;gap:10px}

    .menu-bar{background:var(--bg-secondary);box-shadow:0 2px 8px rgba(0,0,0,.08)}
    .menu-inner{max-width:1250px;margin:0 auto;padding:10px 18px;display:flex;align-items:center;justify-content:space-between;gap:12px}
    .tabs{display:flex;gap:8px;flex-wrap:wrap}
    .menu-actions{display:flex;gap:8px;align-items:center;flex-wrap:wrap}

    .container{max-width:1250px;margin:0 auto;padding:18px}
    .alerta{padding:12px 16px;border-radius:10px;margin-bottom:16px;display:none}
    .alerta.mostrar{display:block}
    .alerta-sucesso{background:#d4edda;color:#155724;border-left:4px solid #28a745}
    .alerta-erro{background:#f8d7da;color:#721c24;border-left:4px solid #dc3545}

    .tab-content{display:none}
    .tab-content.active{display:block}

    .grid{display:grid;grid-template-columns:380px 1fr;gap:22px}
    .panel{background:var(--bg-secondary);padding:22px;border-radius:10px;border-left:4px solid var(--accent-color);box-shadow:var(--shadow-light)}
    .panel h3,.historico-header h3,.relatorios-header h3,.configuracao-header h3{color:var(--accent-color);margin-bottom:16px;font-size:16px}

    .form-group{margin-bottom:8px}
    .form-group label{display:block;margin-bottom:3px;color:var(--text-secondary);font-weight:700;font-size:12px}
    .form-group input,.form-group textarea,.form-group select,.select{
      width:100%;padding:6px 8px;border:2px solid var(--border-color);border-radius:8px;
      font-size:13px;transition:all .2s;background:var(--bg-secondary);color:var(--text-primary);
      box-shadow:var(--shadow-light);
    }
    .form-group input:hover,.form-group textarea:hover,.form-group select:hover,
    .select:hover{box-shadow:var(--shadow-dark),0 0 15px rgba(42,82,152,.2);transform:translateY(-1px)}
    .form-group input:focus,.form-group textarea:focus,.form-group select:focus,
    .select:focus{outline:none;border-color:var(--accent-color);box-shadow:var(--shadow-dark),0 0 20px rgba(42,82,152,.3);transform:translateY(-2px)}

    .extenso-preview{background:#e3f2fd;border:2px solid #2196f3;padding:8px;border-radius:10px;
      margin-top:6px;font-style:italic;color:#1565c0;min-height:38px;font-size:12px;line-height:1.35;box-shadow:var(--shadow-light);text-transform:uppercase}
    body.tema-escuro .extenso-preview{background:#1a3a52;border-color:#4a9eff;color:#4a9eff}

    .row{display:grid;grid-template-columns:1fr 1fr;gap:10px}
    .btn-grid{display:grid;grid-template-columns:1fr 1fr;gap:8px;margin-top:16px}

    /* ── PRÉVIA ── */
    .preview-area{background:var(--bg-secondary);padding:18px;border-radius:10px;display:flex;flex-direction:column;align-items:center;box-shadow:var(--shadow-light)}
    .preview-top{display:flex;justify-content:space-between;align-items:center;width:100%;max-width:17.5cm;margin-bottom:12px}
    .preview-top h3{margin:0;color:var(--accent-color);font-size:16px}

    /* ── CHEQUE FRAME ── */
    #chequeFrame{width:17.5cm;height:7.5cm;overflow:hidden;position:relative;background:#fff}
    .cheque-area{width:17.5cm;height:7.5cm;position:absolute;left:0;top:0;
      background:rgba(255,255,200,.10);border:2px dashed #cfcfcf;
      transform-origin:top left;
      position:relative}
    .cheque-area::before{
      content:"";
      position:absolute;
      top:0;left:0;width:100%;height:100%;
      background-image:url('data:image/jpeg;base64,');
      background-size:cover;
      background-position:center;
      opacity:var(--cheque-bg-opacity);
      pointer-events:none;
      z-index:0}
    .cheque-area.hide-bg::before{opacity:0}
    .campo{position:absolute;font-family:var(--fonte-cheque);color:#000;padding:2px 5px;font-weight:var(--peso-padrao)}
    .campo.ajustavel{cursor:move;border:1px dashed transparent;transition:all .15s}
    .modo-ajuste .campo.ajustavel{border:1px dashed #2196f3;background:rgba(33,150,243,.05)}
    .modo-ajuste .campo.ajustavel:hover{background:rgba(33,150,243,.15);border:1px solid #2196f3}
    .campo.selecionado{outline:2px solid #2196f3;background:rgba(33,150,243,.22)}

    #campoValorNum{top:1.5cm;right:.8cm;font-size:var(--tam-valor-num)}
    #campoExtenso1,#campoExtenso2{left:.7cm;right:.7cm;font-size:var(--tam-extenso);white-space:pre;overflow:hidden}
    #campoExtenso1{top:2.2cm} #campoExtenso2{top:2.9cm}
    #campoNominal{top:4.0cm;left:.7cm;right:3cm;font-size:var(--tam-nominal);white-space:pre;overflow:hidden}
    #campoCidade{top:5.0cm;left:9cm;font-size:var(--tam-data)}
    #campoDia{top:5.0cm;left:13cm;font-size:var(--tam-data)}
    #campoMes{top:5.0cm;left:14.5cm;font-size:var(--tam-data)}
    #campoAno{top:5.0cm;left:16cm;font-size:var(--tam-data)}
    #campoBomPara{top:5.8cm;left:9cm;font-size:var(--tam-bom-para);font-style:italic;color:#444}
#campoNominal,#campoCidade,#campoMes,#campoBomPara{text-transform:uppercase}
    #nominal,#cidade{text-transform:uppercase}

    /* ── HISTÓRICO ── */
    .historico-container,.relatorios-container,.configuracao-container{background:var(--bg-secondary);border-radius:10px;padding:18px;box-shadow:var(--shadow-light)}
    .historico-header,.relatorios-header,.configuracao-header{display:flex;justify-content:space-between;align-items:center;margin-bottom:16px}
    .historico-actions,.relatorios-actions,.configuracao-actions{display:flex;gap:8px}
    .historico-list{max-height:600px;overflow-y:auto}
    .historico-item{background:#f8f9fa;padding:10px;border-radius:8px;margin-bottom:8px;
      border-left:3px solid var(--accent-color);display:flex;justify-content:space-between;
      align-items:center;box-shadow:var(--shadow-light);gap:12px}
    body.tema-escuro .historico-item{background:#3d3d3d}
    .historico-item-info{flex:1;min-width:0}
    .historico-item-valor{font-weight:900;color:var(--accent-color);font-size:15px;margin-bottom:4px}
    .historico-item-nominal{color:var(--text-secondary);font-size:11px;margin-bottom:6px;white-space:nowrap;overflow:hidden;text-overflow:ellipsis}
    .historico-item-data{color:var(--text-tertiary);font-size:10px;margin-top:2px;line-height:1.4}
    .historico-item-meta{display:grid;grid-template-columns:repeat(auto-fit,minmax(120px,1fr));gap:4px 8px;margin-top:4px}
    .historico-item-actions{display:flex;gap:4px;flex-shrink:0}
    .historico-item-actions button{padding:6px 8px;font-size:10px;border-radius:6px;white-space:nowrap}
    .historico-vazio{text-align:center;color:var(--text-tertiary);padding:40px 20px;font-size:14px}

    /* ── RELATÓRIOS ── */
    .stats-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(140px,1fr));gap:12px;margin-bottom:20px}
    .stat-card{padding:16px 12px;border-radius:12px;color:#fff;text-align:center;box-shadow:var(--shadow-light);transition:all .2s}
    .stat-card:hover{box-shadow:var(--shadow-dark);transform:translateY(-2px)}
    .stat-card-label{font-size:11px;font-weight:700;margin-bottom:8px;opacity:.9;text-transform:uppercase;letter-spacing:0.5px}
    .stat-card-value{font-size:24px;font-weight:900;line-height:1.2}
    .stat-card.purple{background:linear-gradient(135deg,#6B46C1,#9F7AEA)}
    .stat-card.pink{background:linear-gradient(135deg,#EC4899,#F472B6)}
    .stat-card.blue{background:linear-gradient(135deg,#3B82F6,#60A5FA)}
    .stat-card.green{background:linear-gradient(135deg,#10B981,#34D399)}
    .relatorios-tabela{width:100%;border-collapse:collapse;margin-top:16px}
    .relatorios-tabela th{background:var(--accent-color);color:#fff;padding:10px;text-align:left;font-size:12px}
    .relatorios-tabela td{padding:10px;border-bottom:1px solid var(--border-color);font-size:12px;color:var(--text-primary)}
    .relatorios-tabela tr:hover{background:var(--bg-primary)}

    /* ── CONFIGURAÇÃO ── */
    .configuracao-section{margin-bottom:24px;padding-bottom:20px;border-bottom:1px solid var(--border-color)}
    .configuracao-section:last-child{border-bottom:none}
    .configuracao-section h4{color:var(--accent-color);margin-bottom:12px;font-size:14px;font-weight:900}
    .configuracao-item{display:flex;justify-content:space-between;align-items:center;margin-bottom:12px;
      padding:12px;background:#f8f9fa;border-radius:8px;box-shadow:var(--shadow-light)}
    body.tema-escuro .configuracao-item{background:#3d3d3d}
    .configuracao-item-label{font-size:13px;color:var(--text-secondary);font-weight:700}
    .configuracao-item-value{font-size:12px;color:var(--text-tertiary)}

    /* ── PAINEL AJUSTE ── */
    .painel-ajuste{position:fixed;top:100px;right:20px;background:var(--bg-secondary);
      box-shadow:var(--shadow-dark);z-index:1000;display:none;max-width:200px;width:200px;
      cursor:move;user-select:none;border:2px solid #0078d4}
    .painel-ajuste.ativo{display:block}
    .painel-ajuste h4{color:#fff;margin:0;font-size:12px;padding:6px 10px;background:#0078d4}
    .painel-ajuste-content{padding:10px}
    .painel-ajuste p{font-size:9px;color:var(--text-secondary);margin-bottom:6px;line-height:1.2}
    .controle{margin-bottom:6px;padding-bottom:6px;border-bottom:1px solid var(--border-color)}
    .controle:last-child{border-bottom:none;padding-bottom:0;margin-bottom:0}
    .controle label{display:block;font-size:9px;font-weight:900;color:var(--text-secondary);margin-bottom:3px}
    .btn-direcao{display:grid;grid-template-columns:repeat(3,1fr);gap:3px}
    .btn-direcao button{padding:4px;border:1px solid var(--border-color);background:var(--bg-secondary);
      border-radius:4px;font-size:12px;font-weight:900;color:var(--text-primary)}
    .mini-row{display:grid;grid-template-columns:1fr 1fr;gap:4px}
    .select{width:auto;padding:4px 6px;border-radius:4px;font-weight:800;font-size:9px;cursor:pointer}

    /* ── MODAL ── */
    .modal-overlay{display:none;position:fixed;top:0;left:0;width:100%;height:100%;
      background:rgba(0,0,0,.5);z-index:2000;align-items:center;justify-content:center}
    .modal-overlay.ativo{display:flex}
    .modal-content{background:var(--bg-secondary);border-radius:12px;padding:32px;
      box-shadow:var(--shadow-dark);max-width:400px;width:90%;animation:slideIn .3s ease}
    @keyframes slideIn{from{opacity:0;transform:translateY(-20px)}to{opacity:1;transform:translateY(0)}}
    .modal-titulo{font-size:20px;font-weight:900;color:var(--text-primary);margin-bottom:24px;text-align:center}
    .modal-opcoes{display:flex;flex-direction:column;gap:16px;margin-bottom:24px}
    .opcao-item{display:flex;align-items:center;gap:12px;padding:12px;border:2px solid var(--border-color);
      border-radius:8px;cursor:pointer;transition:all .2s;background:var(--bg-secondary)}
    .opcao-item:hover{border-color:var(--accent-color);background:rgba(42,82,152,.05)}
    .opcao-item input[type="radio"]{cursor:pointer;width:20px;height:20px;accent-color:var(--accent-color)}
    .opcao-label{font-size:14px;font-weight:700;color:var(--text-primary);cursor:pointer;flex:1}
    .modal-botoes{display:grid;grid-template-columns:1fr 1fr;gap:12px}
    .modal-btn{padding:12px 16px;font-size:14px;font-weight:900;border-radius:8px}

    @media (max-width:1100px){.grid{grid-template-columns:1fr}}
    @media (max-width:768px){.menu-inner{flex-direction:column;align-items:flex-start}}

    /* ── ZONA ADMINISTRATIVA ── */
    .admin-zone{border:2px solid #dc3545;border-radius:10px;padding:18px;margin-top:8px;background:rgba(220,53,69,.04)}
    body.tema-escuro .admin-zone{background:rgba(220,53,69,.08)}
    .admin-zone-header{display:flex;align-items:center;gap:10px;margin-bottom:14px}
    .admin-zone-header h4{color:#dc3545;margin:0;font-size:15px}
    .admin-lock-icon{font-size:20px}
    .admin-zone-desc{font-size:12px;color:#888;margin-bottom:14px;line-height:1.5}
    .admin-zone .configuracao-item{border-left:3px solid #dc354540;padding-left:10px}
    /* ── MODAL SENHA ADMIN ── */
    .modal-admin-overlay{display:none;position:fixed;top:0;left:0;width:100%;height:100%;
      background:rgba(0,0,0,.6);z-index:3000;align-items:center;justify-content:center}
    .modal-admin-overlay.ativo{display:flex}
    .modal-admin-content{background:var(--bg-secondary);border-radius:14px;padding:32px;
      box-shadow:var(--shadow-dark);max-width:360px;width:90%;animation:slideIn .3s ease;
      border-top:4px solid #dc3545}
    .modal-admin-titulo{font-size:18px;font-weight:900;color:#dc3545;margin-bottom:6px;text-align:center}
    .modal-admin-sub{font-size:12px;color:#888;text-align:center;margin-bottom:20px}
    .modal-admin-input{width:100%;padding:12px;border:2px solid var(--border-color);border-radius:8px;
      font-size:15px;background:var(--bg-primary);color:var(--text-primary);box-sizing:border-box;
      letter-spacing:3px;text-align:center;transition:border-color .2s}
    .modal-admin-input:focus{outline:none;border-color:#dc3545}
    .modal-admin-erro{color:#dc3545;font-size:12px;text-align:center;margin-top:8px;
      min-height:18px;font-weight:700}
    .modal-admin-botoes{display:grid;grid-template-columns:1fr 1fr;gap:12px;margin-top:18px}
    .modal-admin-btn-ok{background:#dc3545;color:#fff;border:none;border-radius:8px;
      padding:11px;font-size:14px;font-weight:900;cursor:pointer;transition:opacity .2s}
    .modal-admin-btn-ok:hover{opacity:.85}
    .modal-admin-btn-cancelar{background:var(--bg-primary);color:var(--text-primary);border:2px solid var(--border-color);
      border-radius:8px;padding:11px;font-size:14px;font-weight:700;cursor:pointer}

    /* ── IMPRESSÃO ── */
    @media print {
      @page{size:A4 landscape;margin:0}
      body > *:not(.print-only-container){display:none !important}
      body > .print-only-container{
        display:grid !important;
        place-items:center end !important;
        padding-right:0 !important;
        box-sizing:border-box !important;
        position:absolute !important;
        top:0 !important;
        left:0 !important;
        width:100vw !important;
        height:100vh !important;
        margin:0 !important;
        padding:0 !important;
        background:transparent !important;
        z-index:9999 !important;
      }
      .print-only-container *{visibility:visible !important}
      .cheque-area{border:none !important;background:transparent !important;background-image:none !important}
      .campo.ajustavel{border:none !important}
    }
  </style>
</head>

<body>
  <div class="header">
    <div class="header-top">
      <div>
        <h1>Preenchedor de Cheques</h1>
        <p>S.O.S INFORMÁTICA E IMPRESSORAS - SERVIÇOS GERENCIADOS</p>
      </div>
    </div>
  </div>

  <div class="menu-bar">
    <div class="menu-inner">
      <div class="tabs">
        <button class="tab active" type="button" data-aba="emissao">Emissão</button>
        <button class="tab" type="button" data-aba="historico">Histórico</button>
        <button class="tab" type="button" data-aba="relatorios">Relatórios</button>
        <button class="tab" type="button" data-aba="configuracao">Configuração</button>
      </div>
      <div class="menu-actions">
        <button class="top-btn light" type="button" id="btnToggleAjuste">Ajuste de posição</button>
      </div>
    </div>
  </div>

  <div class="container">
    <div id="alerta" class="alerta"></div>

    <!-- EMISSÃO -->
    <div class="tab-content active" id="emissao">
      <div class="grid">
        <div class="panel">
          <h3>Dados do Cheque</h3>

          <div class="row">
            <div class="form-group">
              <label>Banco</label>
              <select id="banco"><option value="">Selecione</option></select>
            </div>
            <div class="form-group">
              <label>Nº Cheque</label>
              <input type="text" id="numeroCheque" placeholder="Ex.: 180910" inputmode="numeric" />
            </div>
          </div>
          <div class="row">
            <div class="form-group">
              <label>Agência</label>
              <input type="text" id="agencia" placeholder="Ex.: 1342" inputmode="numeric" />
            </div>
