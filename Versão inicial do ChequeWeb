  <script data-cfasync="false" src="/cdn-cgi/scripts/5c5dd728/cloudflare-static/email-decode.min.js"></script><script>
    /* ── CONSTANTES ── */
    const KEYS = {
      printOffset: "print_offset_right_center_v1",
      ajustes:     "ajustesCampos_v2",
      historico:   "historicoCheques_v1",
      tema:        "temaSistema_v1",
      empresa:     "empresa_cfg_v1",
      adminPass:   "adminPassword_v1"
    };

    const BANCOS = ["Banco do Brasil","Caixa Econômica","Sicredi","Sicoob","Itaú","Bradesco"];
    const MESES  = Object.freeze(["janeiro","fevereiro","março","abril","maio","junho","julho","agosto","setembro","outubro","novembro","dezembro"]);
    const GLOBAL_KEY = "__global__";

    /* ── ESTADO ── */
    let modoAjusteAtivo = false;
    let ajustes         = {};
    let campoSelecionado = null;
    let historico       = [];
    let empresaCfg      = { nome:"", cidadeUf:"", endereco:"", cnpj:"", contaInterna:"" };
    let isDragging      = false;
    let dragOffsetX     = 0, dragOffsetY = 0;
    let previewScheduled = false;
    let campoDragging   = false;
    let campoBeingDragged = null;
    let campoStartX     = 0, campoStartY = 0;
    let mouseStartX     = 0, mouseStartY = 0;

    /* ── CACHE DOM (apenas elementos de acesso frequente) ── */
    const el = {};
    function cacheDom() {
      const ids = [
        "alerta","banco","numeroCheque","agencia","conta","valor","valorExtenso",
        "nominal","cidade","data","bomPara",
        "campoValorNum","campoExtenso1","campoExtenso2","campoNominal",
        "campoCidade","campoDia","campoMes","campoAno","campoBomPara",
        "chequeArea","chequeFrame","historicoList",
        "totalCheques","valorTotalCard","esteMes","mediaCard","tabelaRelatoriosBody",
        "selectTema","totalChequesConfig","dataAtualizacao","espacoUtilizado",
        "painelAjuste","painelHeader","campoAtual","passo","alvoOffset",
        "cfgEmpresaNome","cfgEmpresaCidadeUf","cfgEmpresaEndereco","cfgEmpresaCnpj","cfgEmpresaContaInterna",
        "modalImpressao","btnModalSim","btnModalNao"
      ];
      ids.forEach(id => el[id] = document.getElementById(id));
    }

    /* ── UTILIDADES ── */
    function ls(k, v) {
      if (v === undefined) return localStorage.getItem(k);
      localStorage.setItem(k, v);
    }

    function exibirAlerta(msg, tipo) {
      el.alerta.className = "alerta alerta-" + (tipo === "erro" ? "erro" : "sucesso") + " mostrar";
      el.alerta.textContent = msg;
      setTimeout(() => el.alerta.classList.remove("mostrar"), 2500);
    }

    function criarRipple(e) {
      const btn = e.currentTarget;
      const r = btn.getBoundingClientRect();
      const size = Math.max(r.width, r.height);
      const span = document.createElement("span");
      span.className = "ripple";
      span.style.cssText = `width:${size}px;height:${size}px;left:${e.clientX-r.left-size/2}px;top:${e.clientY-r.top-size/2}px`;
      btn.appendChild(span);
      setTimeout(() => span.remove(), 600);
    }

    function pad2(n) { return String(n).padStart(2, "0"); }

    /* ── ABAS ── */
    function abrirAba(nome) {
      document.querySelectorAll(".tab-content").forEach(el => el.classList.remove("active"));
      document.querySelectorAll(".tab").forEach(el => el.classList.remove("active"));
      document.getElementById(nome).classList.add("active");
      document.querySelector(`.tab[data-aba="${nome}"]`).classList.add("active");
      if (nome === "relatorios")   atualizarRelatorios();
      if (nome === "configuracao") atualizarConfiguracao();
    }

    /* ── TEMA ── */
    function aplicarTema(tema) {
      document.body.classList.toggle("tema-escuro", tema === "escuro");
      ls(KEYS.tema, tema);
    }

    /* ── HISTÓRICO ── */
    function salvarHistorico() { ls(KEYS.historico, JSON.stringify(historico)); }

    function adicionarAoHistorico(dados) {
      historico.unshift({ id: Date.now() + Math.random(), dataCriacao: new Date().toLocaleString("pt-BR"), ...dados });
      salvarHistorico();
      renderHistorico();
    }

    function removerDoHistorico(id) {
      historico = historico.filter(c => c.id !== id);
      salvarHistorico();
      renderHistorico();
    }

    function carregarChequeDoHistorico(id) {
      const c = historico.find(c => c.id === id);
      if (!c) return;
      ["banco","numeroCheque","agencia","conta","valor","nominal","cidade","data","bomPara"]
        .forEach(k => { if (el[k]) el[k].value = c[k] || ""; });
      atualizarPreview(false);
      abrirAba("emissao");
      exibirAlerta("Cheque carregado do histórico!", "sucesso");
    }

    function renderHistorico() {
      if (!historico.length) {
        el.historicoList.innerHTML = '<div class="historico-vazio">Nenhum cheque registrado ainda</div>';
        return;
      }
      el.historicoList.innerHTML = historico.map(c => {
        const meta = [
          c.banco && `Banco: ${c.banco}`,
          c.numeroCheque && `Nº: ${c.numeroCheque}`,
          c.agencia && `Ag: ${c.agencia}`,
          c.conta && `Cc: ${c.conta}`,
          c.bomPara && `Bom p/: ${c.bomPara}`
        ].filter(Boolean);
        return `
        <div class="historico-item">
          <div class="historico-item-info">
            <div class="historico-item-valor">R$ ${c.valor || ""}</div>
            <div class="historico-item-nominal">${c.nominal || ""}</div>
            ${meta.length ? `<div class="historico-item-meta">${meta.map(m => `<div class="historico-item-data">${m}</div>`).join('')}</div>` : ''}
            <div class="historico-item-data" style="margin-top:4px">${c.dataCriacao || ""}</div>
          </div>
          <div class="historico-item-actions">
            <button class="btn-carregar" type="button" data-action="carregar" data-id="${c.id}">Carregar</button>
            ${c.htmlCopia ? `<button class="btn-copia" type="button" data-action="copia" data-id="${c.id}">Cópia</button>` : ""}
            <button class="btn-deletar"  type="button" data-action="deletar"  data-id="${c.id}">Deletar</button>
          </div>
        </div>`;
      }).join("");
    }

    /* ── RELATÓRIOS ── */
    function atualizarRelatorios() {
      if (!historico.length) {
        ["totalCheques","esteMes"].forEach(k => el[k].textContent = "0");
        ["valorTotalCard","mediaCard"].forEach(k => el[k].textContent = "R$ 0,00");
        el.tabelaRelatoriosBody.innerHTML = '<tr><td colspan="10" style="text-align:center;">Nenhum cheque registrado ainda</td></tr>';
        return;
      }
      const total = historico.reduce((s, c) => s + parseFloat((c.valor||"").replace(/\./g,"").replace(",",".") || 0), 0);
      const agora = new Date();
      const mesCheques = historico.filter(c => {
        const d = new Date(c.data);
        return d.getMonth() === agora.getMonth() && d.getFullYear() === agora.getFullYear();
      }).length;
      const fmt = v => "R$ " + v.toLocaleString("pt-BR", {minimumFractionDigits:2, maximumFractionDigits:2});
      el.totalCheques.textContent = historico.length;
      el.valorTotalCard.textContent = fmt(total);
      el.esteMes.textContent = mesCheques;
      el.mediaCard.textContent = fmt(total / historico.length);
      el.tabelaRelatoriosBody.innerHTML = historico.map(c => `
        <tr>
          <td>${c.banco||"-"}</td><td>${c.numeroCheque||"-"}</td><td>${c.agencia||"-"}</td><td>${c.conta||"-"}</td>
          <td>R$ ${c.valor||""}</td><td>${c.nominal||""}</td><td>${c.cidade||"-"}</td>
          <td>${c.data||""}</td><td>${c.bomPara||"-"}</td><td>${c.dataCriacao||""}</td>
        </tr>`).join("");
    }

    function atualizarConfiguracao() {
      el.totalChequesConfig.textContent = historico.length;
      el.dataAtualizacao.textContent    = new Date().toLocaleString("pt-BR");
      el.espacoUtilizado.textContent    = (JSON.stringify(historico).length / 1024).toFixed(2) + " KB";
    }

    /* ── AJUSTES DE POSIÇÃO ── */
    function aplicarTransform(elx, dx, dy) { elx.style.transform = `translate(${dx}px,${dy}px)`; }

    function aplicarTodosAjustes() {
      const g = ajustes[GLOBAL_KEY] || { left:0, top:0 };
      document.querySelectorAll(".ajustavel").forEach(elx => {
        const loc = ajustes[elx.dataset.campo] || { left:0, top:0 };
        aplicarTransform(elx, g.left + loc.left, g.top + loc.top);
      });
    }

    function salvarAjustes() { ls(KEYS.ajustes, JSON.stringify(ajustes)); }

    function mover(direcao) {
      const isGlobal = el.alvoOffset.value === "global";
      if (!isGlobal && !campoSelecionado?.dataset?.campo) {
        exibirAlerta("Clique em um campo no cheque antes de mover.", "erro");
        return;
      }
      const key  = isGlobal ? GLOBAL_KEY : campoSelecionado.dataset.campo;
      const step = parseInt(el.passo.value, 10) || 1;
      if (!ajustes[key]) ajustes[key] = { top:0, left:0 };
      const m = { cima:["top",-1], baixo:["top",1], esquerda:["left",-1], direita:["left",1] }[direcao];
      ajustes[key][m[0]] += m[1] * step;
      aplicarTodosAjustes();
      salvarAjustes();
    }


    /* ── DRAG DE CAMPOS COM MOUSE ── */
    function iniciarDragCampo(e) {
      if (!modoAjusteAtivo) return;
      e.preventDefault();
      e.stopPropagation();
      
      campoDragging = true;
      campoBeingDragged = e.currentTarget;
      
      // Seleciona o campo
      document.querySelectorAll(".ajustavel").forEach(x => x.classList.remove("selecionado"));
      campoBeingDragged.classList.add("selecionado");
      campoSelecionado = campoBeingDragged;
      el.campoAtual.textContent = campoBeingDragged.dataset.campo;
      
      const campo = campoBeingDragged.dataset.campo;
      const isGlobal = el.alvoOffset.value === "global";
      const key = isGlobal ? GLOBAL_KEY : campo;
      
      if (!ajustes[key]) ajustes[key] = { left:0, top:0 };
      
      campoStartX = ajustes[key].left;
      campoStartY = ajustes[key].top;
      mouseStartX = e.clientX;
      mouseStartY = e.clientY;
      
      document.body.style.cursor = 'move';
    }
    
    function moverCampoDrag(e) {
      if (!campoDragging || !campoBeingDragged) return;
      e.preventDefault();
      
      const deltaX = e.clientX - mouseStartX;
      const deltaY = e.clientY - mouseStartY;
      
      const campo = campoBeingDragged.dataset.campo;
      const isGlobal = el.alvoOffset.value === "global";
      const key = isGlobal ? GLOBAL_KEY : campo;
      
      ajustes[key].left = campoStartX + deltaX;
      ajustes[key].top  = campoStartY + deltaY;
      
      aplicarTodosAjustes();
    }
    
    function pararDragCampo(e) {
      if (!campoDragging) return;
      e.preventDefault();
      
      campoDragging = false;
      campoBeingDragged = null;
      document.body.style.cursor = '';
      
      salvarAjustes();
    }

    function toggleModoAjuste() {
      modoAjusteAtivo = !modoAjusteAtivo;
      el.chequeArea.classList.toggle("modo-ajuste", modoAjusteAtivo);
      el.painelAjuste.classList.toggle("ativo", modoAjusteAtivo);
      if (modoAjusteAtivo) {
        document.querySelectorAll(".ajustavel").forEach(e => {
          e.onclick = ev => {
            ev.stopPropagation();
            document.querySelectorAll(".ajustavel").forEach(x => x.classList.remove("selecionado"));
            campoSelecionado = ev.currentTarget;
            campoSelecionado.classList.add("selecionado");
            el.campoAtual.textContent = campoSelecionado.dataset.campo;
          };
          e.onmousedown = iniciarDragCampo;
        });
        document.addEventListener("mousemove", moverCampoDrag);
        document.addEventListener("mouseup", pararDragCampo);
      } else {
        campoSelecionado = null;
        campoDragging = false;
        campoBeingDragged = null;
        document.querySelectorAll(".ajustavel").forEach(e => { 
          e.classList.remove("selecionado"); 
          e.onclick = null;
          e.onmousedown = null;
        });
        el.campoAtual.textContent = "Nenhum";
        document.removeEventListener("mousemove", moverCampoDrag);
        document.removeEventListener("mouseup", pararDragCampo);
        document.body.style.cursor = '';
      }
    }

    /* ── CONVERSÃO NUMÉRICA ── */
    function parseBRLToCents(texto) {
      const digits = (texto||"").replace(/\D/g,"").padStart(3,"0");
      return digits ? parseInt(digits.slice(0,-2),10)*100 + parseInt(digits.slice(-2),10) : 0;
    }

    function formatCentsToBRL(cents) {
      return Math.floor(cents/100).toLocaleString("pt-BR") + "," + String(Math.abs(cents%100)).padStart(2,"0");
    }

    function paraExtenso(cents) {
      if (!cents) return "Representação textual do valor";
      const reais = Math.floor(cents/100), centavos = Math.abs(cents%100);
      const un = ["","um","dois","três","quatro","cinco","seis","sete","oito","nove"];
      const dz = ["dez","onze","doze","treze","quatorze","quinze","dezesseis","dezessete","dezoito","dezenove"];
      const dz2= ["","","vinte","trinta","quarenta","cinquenta","sessenta","setenta","oitenta","noventa"];
      const ct = ["","cento","duzentos","trezentos","quatrocentos","quinhentos","seiscentos","setecentos","oitocentos","novecentos"];

      function grp(n) {
        if (!n) return "";
        if (n===100) return "cem";
        const c=Math.floor(n/100), d=Math.floor((n%100)/10), u=n%10;
        let s = c ? ct[c] + (d||u ? " e " : "") : "";
        if (d===1) s+=dz[u];
        else { s += d ? dz2[d] + (u?" e ":"") : ""; s += (u||(!d&&!c)) ? un[u] : ""; }
        return s;
      }

      function num(n) {
        if (!n) return "";
        const mi=Math.floor(n/1000000), rm=n%1000000, mi2=Math.floor(rm/1000), ce=rm%1000;
        let r="";
        if (mi) r += grp(mi)+(mi===1?" milhão":" milhões")+(mi2||ce?", ":"");
        if (mi2) r += (mi2===1?"mil":grp(mi2)+" mil")+(ce?" e ":"");
        if (ce)  r += grp(ce);
        return r;
      }

      let res="";
      if (reais)    res += num(reais)    + (reais===1   ?" real"   :" reais");
      if (centavos) res += (res?" e ":"") + grp(centavos)+ (centavos===1?" centavo":" centavos");
      res = res||"Representação textual do valor";
      return res.charAt(0).toUpperCase()+res.slice(1);
    }

    function preencherAsteriscos(texto, largura) {
      const base = String(texto||"").replace(/\s+/g," ").trim();
      if (!base) return "*".repeat(largura);
      return base.length >= largura ? base.slice(0,largura) : base+"*".repeat(largura-base.length);
    }

    /* ── PREVIEW ── */
    function schedulePreview() {
      if (previewScheduled) return;
      previewScheduled = true;
      requestAnimationFrame(() => { previewScheduled=false; atualizarPreview(false); });
    }

    function atualizarPreview(mostrarAlerta=false) {
      const cents    = parseBRLToCents(el.valor.value);
      const valorFmt = cents ? formatCentsToBRL(cents) : "0,00";
      const extFull  = preencherAsteriscos(cents ? paraExtenso(cents) : "", 124);
      const ext1     = extFull.slice(0,62), ext2 = extFull.slice(62);

      el.campoValorNum.textContent = `(${valorFmt})`;
      el.campoExtenso1.textContent = ext1;
      el.campoExtenso2.textContent = ext2;
      el.campoNominal.textContent  = preencherAsteriscos(el.nominal.value, 55);
      el.campoCidade.textContent   = el.cidade.value||"";

      const dt = el.data.value ? new Date(el.data.value+"T00:00:00") : null;
      el.campoDia.textContent = dt ? dt.getDate()        : "";
      el.campoMes.textContent = dt ? MESES[dt.getMonth()]: "";
      el.campoAno.textContent = dt ? String(dt.getFullYear()).slice(-2) : "";

      const dtBom = el.bomPara.value ? new Date(el.bomPara.value+"T00:00:00") : null;
      el.campoBomPara.textContent = dtBom
        ? `Bom para: ${dtBom.getDate()} de ${MESES[dtBom.getMonth()]} de ${dtBom.getFullYear()}`
        : "";

      aplicarTodosAjustes();
      if (mostrarAlerta) exibirAlerta("Prévia atualizada!", "sucesso");
    }

    /* ── VALIDAÇÃO ── */
    function validarCampos() {
      const checks = [
        [!el.valor.value.trim(),  "Preencha o campo Valor!"],
        [!el.nominal.value.trim(),"Preencha o campo Nominal!"],
        [!el.data.value.trim(),   "Preencha o campo Data!"]
      ];
      for (const [falhou, msg] of checks) {
        if (falhou) { exibirAlerta(msg,"erro"); return false; }
      }
      return true;
    }

    /* ── IMPRESSÃO ── */
    function abrirModal()  { if (validarCampos()) el.modalImpressao.classList.add("ativo"); }
    function fecharModal() { el.modalImpressao.classList.remove("ativo"); }

    function executarImpressao() {
      const tipo = document.querySelector('input[name="tipoImpressao"]:checked').value;
      atualizarPreview(false);

      const dados = {
        valor:el.valor.value, nominal:el.nominal.value, cidade:el.cidade.value,
        data:el.data.value, bomPara:el.bomPara.value||"",
        banco:el.banco.value||"", numeroCheque:el.numeroCheque.value||"",
        agencia:el.agencia.value||"", conta:el.conta.value||""
      };

      fecharModal();

      if (tipo === "frente") {
        adicionarAoHistorico(dados);
        imprimirFrente();
      } else {
        const htmlCopia = gerarHTMLCopiaA4();
        // Procura registro existente com mesmo valor+nominal+data para anexar a cópia
        const existente = historico.find(c =>
          c.valor === dados.valor && c.nominal === dados.nominal && c.data === dados.data
        );
        if (existente) {
          existente.htmlCopia = htmlCopia;
          salvarHistorico();
          renderHistorico();
        } else {
          dados.htmlCopia = htmlCopia;
          adicionarAoHistorico(dados);
        }
        imprimirCopiaA4(htmlCopia);
      }
    }

    function reimprimirCopia(id) {
      const cheque = historico.find(c => c.id === id);
      if (!cheque || !cheque.htmlCopia) { exibirAlerta("Cópia não encontrada!","erro"); return; }
      let iframe = document.getElementById("iframeImpressao");
      if (!iframe) { iframe=document.createElement("iframe"); iframe.id="iframeImpressao"; iframe.style.display="none"; document.body.appendChild(iframe); }
      iframe.contentDocument.open();
      iframe.contentDocument.write(cheque.htmlCopia);
      iframe.contentDocument.close();
      setTimeout(() => iframe.contentWindow.print(), 500);
    }

    function imprimirFrente() {
      const container = document.createElement("div");
      container.className = "print-only-container";
      const clone = el.chequeFrame.cloneNode(true);
      const xMm = getComputedStyle(document.documentElement).getPropertyValue("--print-offset-x").trim();
      const yMm = getComputedStyle(document.documentElement).getPropertyValue("--print-offset-y").trim();
      clone.style.cssText = `position:relative;transform:translate(${xMm},${yMm})`;
      container.appendChild(clone);
      document.body.appendChild(container);
      window.print();
      setTimeout(() => document.body.removeChild(container), 500);
    }

