    /* ── INIT ── */
    function configurarEventos() {
      // Abas
      document.querySelectorAll(".tab").forEach(b => b.onclick = () => abrirAba(b.dataset.aba));

      // Ripple em todos os botões
      document.querySelectorAll(".btn,.tab,.top-btn,.btn-direcao button").forEach(b =>
        b.addEventListener("click", criarRipple));

      // Histórico (único listener unificado)
      el.historicoList.addEventListener("click", ev => {
