          document.getElementById("inputAdminSenha").focus();
        }
      };

      document.getElementById("inputAdminSenha").addEventListener("keydown", e => {
        if (e.key === "Enter") document.getElementById("btnAdminConfirmar").click();
        if (e.key === "Escape") fecharModalAdmin();
      });

      document.getElementById("btnAdminCancelar").onclick = fecharModalAdmin;
      document.getElementById("modalAdminSenha").addEventListener("click", e => {
        if (e.target === document.getElementById("modalAdminSenha")) fecharModalAdmin();
      });

      // Limpar Histórico
      document.getElementById("btnLimparHistorico").onclick = () => {
        abrirModalAdmin("Confirmar exclusão de todo o histórico de cheques", () => {
          if (confirm("Tem certeza? Esta ação não pode ser desfeita!")) {
            historico = []; salvarHistorico(); renderHistorico();
            exibirAlerta("Histórico de cheques limpo com sucesso!", "sucesso");
          }
        });
      };

      // Limpar Todos os Dados
      document.getElementById("btnLimparDados").onclick = () => {
        abrirModalAdmin("Confirmar exclusão de TODOS os dados do sistema", () => {
          if (confirm("ATENÇÃO: Todos os dados serão apagados permanentemente. Confirmar?")) {
            localStorage.clear(); location.reload();
          }
        });
      };

      // Alterar Senha
      document.getElementById("btnAlterarSenha").onclick = () => {
        document.getElementById("inputSenhaAtual").value = "";
        document.getElementById("inputNovaSenha").value = "";
        document.getElementById("modalAlterarErro").textContent = "";
        document.getElementById("modalAlterarSenha").classList.add("ativo");
        setTimeout(() => document.getElementById("inputSenhaAtual").focus(), 100);
      };

      document.getElementById("btnAlterarConfirmar").onclick = () => {
        const atual  = document.getElementById("inputSenhaAtual").value;
        const nova   = document.getElementById("inputNovaSenha").value.trim();
        const erroEl = document.getElementById("modalAlterarErro");
        if (atual !== getSenhaAdmin()) { erroEl.textContent = "Senha atual incorreta."; return; }
        if (nova.length < 4)           { erroEl.textContent = "A nova senha deve ter pelo menos 4 caracteres."; return; }
        ls(KEYS.adminPass, nova);
        document.getElementById("modalAlterarSenha").classList.remove("ativo");
        exibirAlerta("Senha de administrador alterada com sucesso!", "sucesso");
      };

      document.getElementById("btnAlterarCancelarModal").onclick = () => {
        document.getElementById("modalAlterarSenha").classList.remove("ativo");
      };

      document.getElementById("modalAlterarSenha").addEventListener("click", e => {
        if (e.target === document.getElementById("modalAlterarSenha"))
          document.getElementById("modalAlterarSenha").classList.remove("ativo");
      });

      // Relatórios
      document.getElementById("btnAtualizar").onclick = () => { atualizarRelatorios(); exibirAlerta("Relatório atualizado!","sucesso"); };

      document.getElementById("btnImportarCSV").onclick = () => document.getElementById("inputImportarCSV").click();

      document.getElementById("inputImportarCSV").addEventListener("change", function() {
        const file = this.files[0];
        if (!file) return;
        const reader = new FileReader();
        reader.onload = e => {
          const linhas = e.target.result.split("\n").map(l => l.trim()).filter(Boolean);
          if (linhas.length < 2) { exibirAlerta("CSV vazio ou inválido!", "erro"); return; }
          // Pula o cabeçalho (linha 0)
          let importados = 0, duplicados = 0;
          for (let i = 1; i < linhas.length; i++) {
            const cols = linhas[i].match(/(".*?"|[^,]+)(?=,|$)/g) || [];
            const limpar = v => (v||"").replace(/^"|"$/g,"").replace(/""/g,'"').trim();
            const [banco,numeroCheque,agencia,conta,valor,nominal,cidade,data,bomPara,dataCriacao] = cols.map(limpar);
            // Evita importar duplicatas (mesmo valor+nominal+data)
            const jáExiste = historico.some(c => c.valor===valor && c.nominal===nominal && c.data===data);
            if (jáExiste) { duplicados++; continue; }
            historico.push({
              id: Date.now() + Math.random(),
              banco, numeroCheque, agencia, conta, valor,
              nominal, cidade, data, bomPara,
              dataCriacao: dataCriacao || new Date().toLocaleString("pt-BR")
            });
            importados++;
          }
          salvarHistorico();
          renderHistorico();
          atualizarRelatorios();
          const msg = `${importados} cheque(s) importado(s)` + (duplicados ? `, ${duplicados} duplicata(s) ignorada(s).` : ".");
          exibirAlerta(msg, importados > 0 ? "sucesso" : "erro");
          this.value = "";
        };
        reader.readAsText(file, "UTF-8");
      });
      document.getElementById("btnExportarCSV").onclick = () => {
        if (!historico.length) { exibirAlerta("Nenhum dado para exportar!","erro"); return; }
        const header = "Banco,Nº Cheque,Agência,Conta,Valor,Beneficiário,Cidade,Data,Bom para,Registrado em";
        const rows   = historico.map(c =>
          [c.banco,c.numeroCheque,c.agencia,c.conta,c.valor,c.nominal,c.cidade,c.data,c.bomPara,c.dataCriacao]
            .map(v => `"${(v||"").replace(/"/g,'""')}"`)
            .join(",")
        );
        const blob = new Blob([[header,...rows].join("\n")], {type:"text/csv;charset=utf-8;"});
        const a = document.createElement("a");
        a.href = URL.createObjectURL(blob);
        a.download = "cheques.csv";
        a.click();
      };

      // Configuração
      document.getElementById("btnSalvarConfig").onclick = () => { lerFormEmpresa(); salvarEmpresaCfg(); exibirAlerta("Configurações salvas!","sucesso"); };

      // Drag do painel
      el.painelHeader.addEventListener("mousedown", iniciarDrag);
      document.addEventListener("mousemove", moverDrag);
      document.addEventListener("mouseup", () => isDragging=false);
    }

    function carregarEstadoInicial() {
      const temaSalvo = ls(KEYS.tema) || "claro";
      aplicarTema(temaSalvo);
      el.selectTema.value = temaSalvo;

      const offsets = JSON.parse(ls(KEYS.printOffset)||"{}");
      const xMm = typeof offsets.xMm==="number" ? offsets.xMm : 0;
      const yMm = typeof offsets.yMm==="number" ? offsets.yMm : 0;
      document.documentElement.style.setProperty("--print-offset-x", xMm+"mm");
      document.documentElement.style.setProperty("--print-offset-y", yMm+"mm");

      ajustes  = JSON.parse(ls(KEYS.ajustes)  || "{}");
      historico= JSON.parse(ls(KEYS.historico) || "[]");

      carregarEmpresaCfg();
      preencherFormEmpresa();

      el.banco.innerHTML = '<option value="">Selecione</option>' +
        BANCOS.map(b => `<option value="${b}">${b}</option>`).join("");
    }

    function init() {
      cacheDom();
      carregarEstadoInicial();
      configurarEventos();
      aplicarTodosAjustes();
      renderHistorico();

      // Data de hoje como padrão
      const h = new Date();
      el.data.value = `${h.getFullYear()}-${pad2(h.getMonth()+1)}-${pad2(h.getDate())}`;

      atualizarPreview(false);
    }

    document.addEventListener("DOMContentLoaded", init);
  </script>
</body>
</html>
