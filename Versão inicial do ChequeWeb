      // ── ZONA ADMINISTRATIVA (senha protegida) ──
      const SENHA_PADRAO = "admin123";
      let adminAcaoPendente = null; // guarda qual ação será executada após autenticação

      function getSenhaAdmin() {
        return ls(KEYS.adminPass) || SENHA_PADRAO;
      }

      function abrirModalAdmin(subtitulo, acaoCallback) {
        adminAcaoPendente = acaoCallback;
        document.getElementById("modalAdminSubtitulo").textContent = subtitulo;
        document.getElementById("inputAdminSenha").value = "";
        document.getElementById("modalAdminErro").textContent = "";
