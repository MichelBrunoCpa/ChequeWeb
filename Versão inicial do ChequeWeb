          ajustes={}; salvarAjustes(); aplicarTodosAjustes(); exibirAlerta("Posições resetadas!","sucesso");
        }
      };

      document.getElementById("btnResetPrintOffset").onclick = () => {
        document.documentElement.style.setProperty("--print-offset-x", "0mm");
        document.documentElement.style.setProperty("--print-offset-y", "0mm");
